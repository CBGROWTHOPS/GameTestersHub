---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Gaming Resources & Earning Guides" description="GameTestersHub — guides, reviews, and resources for gamers. Learn about game testing, earning platforms, gear, and more.">

  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <h1>The Gamer's Guide to<br><span class="gradient-text">Testing & Earning</span></h1>
      <p class="hero-subtitle">Honest reviews, real guides, and practical resources for gamers who want to turn their hobby into income.</p>
      <div class="hero-buttons">
        <a href="/start" class="cta-button primary">Find Games That Pay</a>
      </div>
    </div>
    <div class="hero-glow"></div>
  </section>

  <!-- Guides & Resources — lead with content -->
  <section class="home-section">
    <div class="container">
      <div class="section-top">
        <h2>Guides & Resources</h2>
        <a href="/guides" class="view-all">View All →</a>
      </div>
      <div class="card-grid">
        <a href="/guides/truth-about-game-testing" class="card">
          <span class="card-tag">Getting Started</span>
          <h3>The Truth About Game Testing Jobs</h3>
          <p>What's real, what's hype, and how to actually get paid testing games in 2026. We break down both professional QA and side-income opportunities.</p>
          <div class="card-meta">
            <span>10 min read</span>
          </div>
        </a>
        <a href="/guides/best-gaming-setup-under-500" class="card">
          <span class="card-tag">Gear Guide</span>
          <h3>Best Gaming Setup Under $500</h3>
          <p>Everything you need for a solid gaming setup without breaking the bank. Budget builds, peripherals, and what actually matters.</p>
          <div class="card-meta">
            <span>8 min read</span>
          </div>
        </a>
        <a href="/guides/maximize-freecash-earnings" class="card">
          <span class="card-tag">Earning Tips</span>
          <h3>How to Maximize Earnings on Reward Platforms</h3>
          <p>Pro tips for getting the best $/hour on GPT platforms. Which offers to take, which to skip, and how to stack earnings.</p>
          <div class="card-meta">
            <span>7 min read</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Platform Reviews — informational, not sales -->
  <section class="home-section">
    <div class="container">
      <div class="section-top">
        <h2>Platform Reviews</h2>
        <a href="/reviews" class="view-all">View All →</a>
      </div>
      <p class="section-desc">We test every platform so you don't waste your time. Honest ratings based on real usage.</p>
      <div class="card-grid">
        <a href="/reviews/freecash" class="card">
          <span class="card-tag">Rewards Platform</span>
          <h3>FreeCash</h3>
          <p>One of the largest GPT platforms with gaming offers, surveys, and a low cashout minimum. Our full breakdown.</p>
          <div class="card-meta">
            <span class="stars">★★★★★</span>
            <span>9.5/10</span>
          </div>
        </a>
        <a href="/reviews/playtestcloud" class="card">
          <span class="card-tag">Game Testing</span>
          <h3>PlaytestCloud</h3>
          <p>Actual game testing for real studios. Play unreleased games and give feedback. Limited availability but legit.</p>
          <div class="card-meta">
            <span class="stars">★★★★☆</span>
            <span>8.5/10</span>
          </div>
        </a>
        <a href="/reviews/inboxdollars" class="card">
          <span class="card-tag">Rewards Platform</span>
          <h3>InboxDollars</h3>
          <p>Established since 2006 with a $5 signup bonus. Games, surveys, and videos. Higher cashout minimum.</p>
          <div class="card-meta">
            <span class="stars">★★★★☆</span>
            <span>8.0/10</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- How it Works — educational -->
  <section class="home-section">
    <div class="container" style="text-align: center;">
      <h2 style="font-size: clamp(1.5rem, 3vw, 2.25rem); margin-bottom: 16px;">How Do Gamers Earn Money?</h2>
      <p class="section-desc" style="text-align: center; max-width: 600px; margin: 0 auto 48px;">There are several legitimate ways to earn through gaming. Here's the landscape.</p>
      <div class="steps-grid">
        <div class="step-card">
          <div class="step-num">1</div>
          <h3>Reward Platforms</h3>
          <p>Complete gaming offers, surveys, and tasks on GPT sites. Easiest entry point — no skills required.</p>
        </div>
        <div class="step-card">
          <div class="step-num">2</div>
          <h3>Game Testing</h3>
          <p>Play unreleased games and give feedback to developers. Pays well per session but limited availability.</p>
        </div>
        <div class="step-card">
          <div class="step-num">3</div>
          <h3>Content & Streaming</h3>
          <p>Build an audience on YouTube, Twitch, or TikTok. Higher ceiling but requires time and consistency.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="home-section">
    <div class="container">
      <h2 style="text-align: center; font-size: clamp(1.5rem, 3vw, 2.25rem); margin-bottom: 48px;">From the Community</h2>
      <div class="card-grid">
        <div class="card">
          <div class="stars" style="margin-bottom: 12px;">★★★★★</div>
          <p>"The game testing guide saved me from wasting time on scam sites. Ended up finding legit platforms and making $200/month on the side."</p>
          <div class="card-meta">
            <span><strong>Marcus K.</strong> — Texas</span>
          </div>
        </div>
        <div class="card">
          <div class="stars" style="margin-bottom: 12px;">★★★★★</div>
          <p>"Honest reviews are hard to find in this space. Most sites just push whatever pays them the most. This one actually tells you the downsides."</p>
          <div class="card-meta">
            <span><strong>Sarah R.</strong> — Florida</span>
          </div>
        </div>
        <div class="card">
          <div class="stars" style="margin-bottom: 12px;">★★★★★</div>
          <p>"The gear guide helped me build a solid setup for under $400. Practical advice without trying to sell me overpriced stuff."</p>
          <div class="card-meta">
            <span><strong>James T.</strong> — California</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Subtle CTA -->
  <section class="final-cta-section">
    <div class="container" style="text-align: center; position: relative; z-index: 1;">
      <h2>Not Sure Where to Start?</h2>
      <p>Take a quick quiz to find the best earning opportunities for your gaming style and schedule.</p>
      <a href="/start" class="cta-button primary">
        Take the Quiz
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <p class="cta-sub">60 seconds • No signup required</p>
    </div>
    <div class="hero-glow" style="top: 50%; left: 50%; transform: translate(-50%, -50%); width: 600px; height: 600px; position: absolute;"></div>
  </section>

</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 24px 80px;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 800px;
    background: var(--gradient-glow);
    pointer-events: none;
    z-index: 0;
  }

  .hero .container {
    position: relative;
    z-index: 1;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto 40px;
  }

  .hero-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 18px 36px;
    font-size: 18px;
    font-weight: 600;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    text-decoration: none;
  }

  .cta-button.primary {
    background: var(--gradient-primary);
    color: white;
    box-shadow: var(--shadow-glow);
  }

  .cta-button.primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 60px rgba(139, 92, 246, 0.5);
    color: white;
  }

  .cta-button.secondary {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
  }

  .cta-button.secondary:hover {
    border-color: var(--accent-purple);
    background: rgba(139, 92, 246, 0.1);
    color: var(--text-primary);
  }

  .section-desc {
    color: var(--text-secondary);
    font-size: 16px;
    margin-bottom: 32px;
    line-height: 1.6;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .step-card {
    text-align: center;
  }

  .step-num {
    width: 64px;
    height: 64px;
    background: var(--gradient-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    font-weight: 700;
    margin: 0 auto 20px;
    color: white;
  }

  .step-card h3 {
    font-size: 20px;
    margin-bottom: 12px;
  }

  .step-card p {
    color: var(--text-secondary);
    font-size: 15px;
  }

  .final-cta-section {
    padding: 100px 24px;
    background: var(--bg-secondary);
    position: relative;
    overflow: hidden;
  }

  .final-cta-section h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: 16px;
  }

  .final-cta-section > .container > p {
    color: var(--text-secondary);
    font-size: 18px;
    margin-bottom: 32px;
  }

  .cta-sub {
    margin-top: 16px;
    font-size: 14px;
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .hero {
      padding: 100px 24px 60px;
      min-height: auto;
    }
    .steps-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
