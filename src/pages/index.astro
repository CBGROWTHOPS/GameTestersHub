---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Earn Money Gaming" description="GameTestersHub — your hub for earning money through gaming. Platform reviews, gear guides, game testing resources, and real earning opportunities.">

  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero-badge">Your Gaming Earning Hub</div>
      <h1>Turn Your Gaming<br>Into <span class="gradient-text">Real Income</span></h1>
      <p class="hero-subtitle">Reviews, guides, and real opportunities to earn money doing what you already love — playing games.</p>
      <div class="hero-buttons">
        <a href="/reviews" class="cta-button primary">Explore Platforms</a>
        <a href="/start" class="cta-button secondary">Take the Quiz</a>
      </div>
      <div class="trust-badges">
        <div class="trust-item">
          <span class="trust-number">15+</span>
          <span class="trust-label">Platforms Reviewed</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <span class="trust-number">$50M+</span>
          <span class="trust-label">Paid to Users</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <span class="trust-number">100%</span>
          <span class="trust-label">Free to Start</span>
        </div>
      </div>
    </div>
    <div class="hero-glow"></div>
  </section>

  <!-- Featured Platform -->
  <section class="home-section featured-section">
    <div class="container">
      <div class="featured-card">
        <div class="featured-badge">Featured Platform</div>
        <div class="featured-content">
          <div class="featured-info">
            <h2>FreeCash</h2>
            <div class="stars">★★★★★</div>
            <p>The #1 platform for earning money through gaming tasks, surveys, and offers. Over $50 million paid out to users worldwide. Sign up takes 30 seconds.</p>
            <ul class="featured-perks">
              <li>Earn playing mobile games</li>
              <li>Cash out via PayPal, crypto, or gift cards</li>
              <li>$1 minimum withdrawal</li>
              <li>Available worldwide</li>
            </ul>
            <a href="https://trk.ssaff.link/gth-freecash" class="cta-button primary" target="_blank" rel="noopener">
              Start Earning on FreeCash
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="featured-score">
            <div class="score-circle">
              <span class="score-num">9.5</span>
              <span class="score-label">/ 10</span>
            </div>
            <a href="/reviews/freecash" class="read-review">Read Full Review →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Platform Reviews -->
  <section class="home-section">
    <div class="container">
      <div class="section-top">
        <h2>Platform Reviews</h2>
        <a href="/reviews" class="view-all">View All Reviews →</a>
      </div>
      <div class="card-grid">
        <a href="/reviews/freecash" class="card">
          <span class="card-tag">Rewards Platform</span>
          <h3>FreeCash Review</h3>
          <p>Earn cash playing games, completing offers, and taking surveys. Our top pick for beginners.</p>
          <div class="card-meta">
            <span class="stars">★★★★★</span>
            <span>9.5/10</span>
          </div>
        </a>
        <a href="/reviews/inboxdollars" class="card">
          <span class="card-tag">Rewards Platform</span>
          <h3>InboxDollars Review</h3>
          <p>Get a $5 signup bonus and earn through games, videos, and surveys. Established since 2006.</p>
          <div class="card-meta">
            <span class="stars">★★★★☆</span>
            <span>8.0/10</span>
          </div>
        </a>
        <a href="/reviews/playtestcloud" class="card">
          <span class="card-tag">Game Testing</span>
          <h3>PlaytestCloud Review</h3>
          <p>Get paid to playtest real games before release. Legit game testing with actual developer feedback.</p>
          <div class="card-meta">
            <span class="stars">★★★★☆</span>
            <span>8.5/10</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Guides -->
  <section class="home-section">
    <div class="container">
      <div class="section-top">
        <h2>Guides & Resources</h2>
        <a href="/guides" class="view-all">View All Guides →</a>
      </div>
      <div class="card-grid">
        <a href="/guides/truth-about-game-testing" class="card">
          <span class="card-tag">Getting Started</span>
          <h3>The Truth About Game Testing Jobs</h3>
          <p>What's real, what's hype, and how to actually get paid testing games in 2026.</p>
          <div class="card-meta">
            <span>10 min read</span>
          </div>
        </a>
        <a href="/guides/maximize-freecash-earnings" class="card">
          <span class="card-tag">Earning Tips</span>
          <h3>How to Maximize Your FreeCash Earnings</h3>
          <p>Pro tips and strategies to earn more per hour on FreeCash.</p>
          <div class="card-meta">
            <span>7 min read</span>
          </div>
        </a>
        <a href="/guides/best-gaming-setup-under-500" class="card">
          <span class="card-tag">Gear Guide</span>
          <h3>Best Gaming Setup Under $500</h3>
          <p>Everything you need to start gaming and earning without breaking the bank.</p>
          <div class="card-meta">
            <span>8 min read</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- How it Works -->
  <section class="home-section">
    <div class="container" style="text-align: center;">
      <h2 style="font-size: clamp(1.5rem, 3vw, 2.25rem); margin-bottom: 48px;">How It Works</h2>
      <div class="steps-grid">
        <div class="step-card">
          <div class="step-num">1</div>
          <h3>Explore Platforms</h3>
          <p>Read our honest reviews to find the right earning platforms for you</p>
        </div>
        <div class="step-card">
          <div class="step-num">2</div>
          <h3>Sign Up Free</h3>
          <p>Create accounts on the platforms that match your interests — always free</p>
        </div>
        <div class="step-card">
          <div class="step-num">3</div>
          <h3>Start Earning</h3>
          <p>Complete tasks, play games, and cash out via PayPal, crypto, or gift cards</p>
        </div>
      </div>
      <a href="/start" class="cta-button primary" style="margin-top: 40px;">
        Find Your Best Platforms
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="home-section">
    <div class="container">
      <h2 style="text-align: center; font-size: clamp(1.5rem, 3vw, 2.25rem); margin-bottom: 48px;">What Our Community Says</h2>
      <div class="card-grid">
        <div class="card">
          <div class="stars" style="margin-bottom: 12px;">★★★★★</div>
          <p>"Started with FreeCash from this site. Made $200 my first month just doing gaming offers in my spare time."</p>
          <div class="card-meta">
            <span><strong>Marcus K.</strong> — Texas</span>
          </div>
        </div>
        <div class="card">
          <div class="stars" style="margin-bottom: 12px;">★★★★★</div>
          <p>"The reviews here saved me so much time. I knew exactly which platforms were worth it before signing up."</p>
          <div class="card-meta">
            <span><strong>Sarah R.</strong> — Florida</span>
          </div>
        </div>
        <div class="card">
          <div class="stars" style="margin-bottom: 12px;">★★★★★</div>
          <p>"The gear guide helped me build a solid setup for under $400. Now I game and earn at the same time."</p>
          <div class="card-meta">
            <span><strong>James T.</strong> — California</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta-section">
    <div class="container" style="text-align: center; position: relative; z-index: 1;">
      <h2>Ready to Start Earning?</h2>
      <p>Take our 60-second quiz to find the best earning opportunities for your gaming style.</p>
      <a href="/start" class="cta-button primary large">
        Take the Quiz
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <p class="cta-sub">Free to join • No credit card required</p>
    </div>
    <div class="hero-glow" style="top: 50%; left: 50%; transform: translate(-50%, -50%); width: 600px; height: 600px; position: absolute;"></div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 24px 80px;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 800px;
    background: var(--gradient-glow);
    pointer-events: none;
    z-index: 0;
  }

  .hero .container {
    position: relative;
    z-index: 1;
  }

  .hero-badge {
    display: inline-block;
    padding: 8px 20px;
    background: rgba(139, 92, 246, 0.2);
    border: 1px solid var(--accent-purple);
    border-radius: 100px;
    font-size: 14px;
    font-weight: 500;
    color: var(--accent-purple);
    margin-bottom: 24px;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto 40px;
  }

  .hero-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 18px 36px;
    font-size: 18px;
    font-weight: 600;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    text-decoration: none;
  }

  .cta-button.primary {
    background: var(--gradient-primary);
    color: white;
    box-shadow: var(--shadow-glow);
  }

  .cta-button.primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 60px rgba(139, 92, 246, 0.5);
    color: white;
  }

  .cta-button.secondary {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
  }

  .cta-button.secondary:hover {
    border-color: var(--accent-purple);
    background: rgba(139, 92, 246, 0.1);
    color: var(--text-primary);
  }

  .cta-button.large {
    padding: 22px 48px;
    font-size: 20px;
  }

  .trust-badges {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 32px;
    margin-top: 60px;
    flex-wrap: wrap;
  }

  .trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .trust-number {
    font-size: 28px;
    font-weight: 700;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .trust-label {
    font-size: 14px;
    color: var(--text-secondary);
    margin-top: 4px;
  }

  .trust-divider {
    width: 1px;
    height: 40px;
    background: var(--border-color);
  }

  /* Featured */
  .featured-section {
    background: var(--bg-secondary);
  }

  .featured-card {
    background: var(--bg-card);
    border: 1px solid var(--accent-purple);
    border-radius: 20px;
    padding: 40px;
    position: relative;
    overflow: hidden;
  }

  .featured-badge {
    display: inline-block;
    padding: 6px 16px;
    background: var(--gradient-primary);
    border-radius: 100px;
    font-size: 13px;
    font-weight: 600;
    color: white;
    margin-bottom: 24px;
  }

  .featured-content {
    display: flex;
    gap: 40px;
    align-items: center;
  }

  .featured-info {
    flex: 1;
  }

  .featured-info h2 {
    font-size: 32px;
    margin-bottom: 8px;
  }

  .featured-info > p {
    color: var(--text-secondary);
    font-size: 16px;
    margin: 16px 0;
    line-height: 1.7;
  }

  .featured-perks {
    list-style: none;
    margin: 20px 0 28px;
    padding: 0;
  }

  .featured-perks li {
    padding: 4px 0 4px 24px;
    position: relative;
    color: var(--text-secondary);
    font-size: 15px;
  }

  .featured-perks li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--accent-green);
    font-weight: 700;
  }

  .featured-score {
    text-align: center;
    flex-shrink: 0;
  }

  .score-circle {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: rgba(139, 92, 246, 0.15);
    border: 2px solid var(--accent-purple);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin: 0 auto 12px;
  }

  .score-num {
    font-size: 36px;
    font-weight: 800;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }

  .score-label {
    font-size: 14px;
    color: var(--text-secondary);
  }

  .read-review {
    font-size: 14px;
    color: var(--accent-cyan);
    font-weight: 500;
  }

  /* Steps */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .step-card {
    text-align: center;
  }

  .step-num {
    width: 64px;
    height: 64px;
    background: var(--gradient-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    font-weight: 700;
    margin: 0 auto 20px;
    color: white;
  }

  .step-card h3 {
    font-size: 20px;
    margin-bottom: 12px;
  }

  .step-card p {
    color: var(--text-secondary);
    font-size: 15px;
  }

  /* Final CTA */
  .final-cta-section {
    padding: 120px 24px;
    background: var(--bg-secondary);
    position: relative;
    overflow: hidden;
  }

  .final-cta-section h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 16px;
  }

  .final-cta-section > .container > p {
    color: var(--text-secondary);
    font-size: 18px;
    margin-bottom: 32px;
  }

  .cta-sub {
    margin-top: 16px;
    font-size: 14px;
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .hero {
      padding: 100px 24px 60px;
      min-height: auto;
    }
    .trust-divider {
      display: none;
    }
    .featured-content {
      flex-direction: column;
    }
    .featured-card {
      padding: 28px;
    }
    .steps-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
