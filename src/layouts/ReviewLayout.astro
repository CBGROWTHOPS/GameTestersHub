---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title: string;
  description: string;
  platform: string;
  score: string;
  scoreLabel: string;
  category: string;
  pros: string[];
  cons: string[];
  info: { label: string; value: string }[];
  ctaLink?: string;
  ctaText?: string;
}

const {
  title,
  description,
  platform,
  score,
  scoreLabel,
  category,
  pros,
  cons,
  info,
  ctaLink,
  ctaText = "Visit Platform",
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="page-layout">
    <div class="page-content">
      <nav class="breadcrumbs">
        <a href="/">Home</a>
        <span class="separator">/</span>
        <a href="/reviews">Reviews</a>
        <span class="separator">/</span>
        <span>{platform}</span>
      </nav>

      <div class="section-header">
        <span class="review-category">{category}</span>
        <h1>{title}</h1>
      </div>

      <div class="review-score">
        <div class="score-number">{score}</div>
        <div class="score-details">
          <h3>{scoreLabel}</h3>
          <div class="stars">{"★".repeat(Math.round(parseFloat(score) / 2))}{"☆".repeat(5 - Math.round(parseFloat(score) / 2))}</div>
        </div>
      </div>

      <table class="info-table">
        {info.map((row) => (
          <tr>
            <td>{row.label}</td>
            <td>{row.value}</td>
          </tr>
        ))}
      </table>

      <div class="pros-cons">
        <div class="pros">
          <h4>Pros</h4>
          <ul>
            {pros.map((pro) => <li>{pro}</li>)}
          </ul>
        </div>
        <div class="cons">
          <h4>Cons</h4>
          <ul>
            {cons.map((con) => <li>{con}</li>)}
          </ul>
        </div>
      </div>

      <div class="article-content">
        <slot />
      </div>

      {ctaLink && (
        <div class="bottom-cta">
          <a href={ctaLink} class="review-link" target="_blank" rel="noopener">
            {ctaText} →
          </a>
        </div>
      )}
    </div>
    <Sidebar />
  </div>
</BaseLayout>

<style>
  .review-category {
    display: inline-block;
    padding: 4px 14px;
    background: rgba(139, 92, 246, 0.15);
    border-radius: 100px;
    color: var(--accent-purple);
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .bottom-cta {
    margin-top: 40px;
    padding-top: 24px;
    border-top: 1px solid var(--border-color);
  }

  .review-link {
    font-size: 16px;
    font-weight: 500;
    color: var(--accent-cyan);
    text-decoration: none;
  }

  .review-link:hover {
    color: var(--accent-purple);
  }
</style>
